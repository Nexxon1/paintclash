{
  "name": "@paintclash/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --var COMMIT_SHA:$(git rev-parse HEAD)"
  },
  "dependencies": {
    "@paintclash/protocol": "workspace:*",
    "@paintclash/shared": "workspace:*",
    "@paintclash/sim-core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1"
  }
}
